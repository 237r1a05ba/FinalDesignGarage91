{% comment %}
  Elite Moto Parts - Vehicle Search Strip
  Designed for Shopify as a section.
{% endcomment %}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;700;900&display=swap');

  #shopify-section-{{ section.id }} {
    --primary-red: {{ section.settings.accent_color }};
    --bg-dark: {{ section.settings.bg_color }};
    --card-bg: #0a0a0a;
    --text-white: #ffffff;
    --text-dim: rgba(255, 255, 255, 0.4);
    --border-color: rgba(255, 255, 255, 0.1);
  }

  .moto-search-wrapper {
    background-color: var(--bg-dark);
    padding: 60px 20px;
    font-family: 'Inter', sans-serif;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 200px;
  }

  .moto-search-container {
    max-width: 1200px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Header Styles */
  .moto-header {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 0 8px;
  }

  @media (min-width: 768px) {
    .moto-header {
      flex-direction: row;
      align-items: center;
      gap: 16px;
    }
  }

  .moto-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--primary-red);
  }

  .moto-badge svg {
    width: 16px;
    height: 16px;
    fill: var(--primary-red);
  }

  .moto-badge span {
    font-size: 9px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.4em;
    white-space: nowrap;
  }

  .moto-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    line-height: 1;
    color: var(--text-white);
    letter-spacing: 0.1em;
    margin: 0;
  }

  .moto-title span {
    color: var(--primary-red);
  }

  /* Search Bar Styles */
  .moto-search-bar-wrap {
    position: relative;
  }

  .moto-search-glow {
    position: absolute;
    inset: -4px;
    background: linear-gradient(to right, rgba(153, 27, 27, 0.2), var(--primary-red), rgba(153, 27, 27, 0.2));
    border-radius: 20px;
    filter: blur(15px);
    opacity: 0.1;
    transition: opacity 1s;
  }

  .moto-search-bar-wrap:hover .moto-search-glow {
    opacity: 0.3;
  }

  .moto-search-bar {
    position: relative;
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 12px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
  }

  @media (min-width: 1024px) {
    .moto-search-bar {
      flex-direction: row;
      padding: 12px;
    }
  }

  .moto-dropdown-group {
    flex: 1;
    position: relative;
  }

  .moto-select {
    width: 100%;
    height: 56px;
    background-color: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 0 16px;
    color: var(--text-white);
    font-size: 13px;
    font-weight: 500;
    appearance: none;
    cursor: pointer;
    transition: all 0.3s;
    outline: none;
  }

  .moto-select:hover {
    background-color: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .moto-select:focus {
    border-color: var(--primary-red);
    box-shadow: 0 0 0 2px rgba(220, 38, 38, 0.2);
  }

  .moto-select option {
    background-color: #1a1a1a;
    color: white;
  }

  .moto-chevron {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    width: 16px;
    height: 16px;
    color: #666;
    pointer-events: none;
    transition: color 0.3s;
  }

  .moto-dropdown-group:hover .moto-chevron {
    color: var(--primary-red);
  }

  /* Button Styles */
  .moto-search-btn {
    flex: 0.6;
    height: 56px;
    background-color: var(--primary-red);
    color: white;
    border: none;
    border-radius: 12px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    letter-spacing: 0.1em;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    position: relative;
    overflow: hidden;
    transition: all 0.3s;
    box-shadow: 0 10px 15px -3px rgba(220, 38, 38, 0.3);
  }

  .moto-search-btn:hover {
    background-color: #b91c1c;
    transform: translateY(-1px);
  }

  .moto-search-btn:active {
    transform: scale(0.98);
  }

  .moto-btn-shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    transform: translateX(-100%) skewX(-12deg);
    transition: transform 0.7s;
  }

  .moto-search-btn:hover .moto-btn-shimmer {
    transform: translateX(100%) skewX(-12deg);
  }

  .moto-search-btn svg {
    width: 18px;
    height: 18px;
  }
</style>

<section class="moto-search-wrapper">
  <div class="moto-search-container">
    
    <div class="moto-header">
      <div class="moto-badge">
        <svg viewBox="0 0 24 24"><path d="M13 10V3L4 14H11V21L20 10H13Z"/></svg>
        <span>{{ section.settings.badge_text }}</span>
      </div>
      <h2 class="moto-title">
        {{ section.settings.title_part1 }} <span>{{ section.settings.title_part2 }}</span>
      </h2>
    </div>

    <div class="moto-search-bar-wrap">
      <div class="moto-search-glow"></div>
      
      <form id="moto-search-form" action="/search" method="get" class="moto-search-bar">
        <input type="hidden" name="type" value="product">
        {% comment %} The 'q' parameter is what Shopify uses for the main search query {% endcomment %}
        <input type="hidden" name="q" id="moto-final-query" value="">
        
        <div class="moto-dropdown-group">
          <select class="moto-select" id="moto-brand" required>
            <option value="" disabled selected>{{ section.settings.label_brand }}</option>
            {% assign brands = section.settings.brands | split: ',' %}
            {% for brand in brands %}
              <option value="{{ brand | strip }}">{{ brand | strip }}</option>
            {% endfor %}
          </select>
          <svg class="moto-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </div>

        <div class="moto-dropdown-group">
          <select class="moto-select" id="moto-model" required>
            <option value="" disabled selected>{{ section.settings.label_model }}</option>
            {% assign models = section.settings.models | split: ',' %}
            {% for model in models %}
              <option value="{{ model | strip }}">{{ model | strip }}</option>
            {% endfor %}
          </select>
          <svg class="moto-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </div>

        <div class="moto-dropdown-group">
          <select class="moto-select" id="moto-category">
            <option value="" selected>{{ section.settings.label_category }}</option>
            <option value="all">All Categories</option>
            {% assign categories = section.settings.categories | split: ',' %}
            {% for category in categories %}
              <option value="{{ category | strip }}">{{ category | strip }}</option>
            {% endfor %}
          </select>
          <svg class="moto-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </div>

        <button type="submit" class="moto-search-btn">
          <div class="moto-btn-shimmer"></div>
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
          {{ section.settings.button_text }}
        </button>
      </form>
    </div>

  </div>
</section>

<script>
  document.getElementById('moto-search-form').addEventListener('submit', function(e) {
    const brand = document.getElementById('moto-brand').value;
    const model = document.getElementById('moto-model').value;
    const category = document.getElementById('moto-category').value;
    const queryInput = document.getElementById('moto-final-query');
    
    if (!brand || !model) {
      e.preventDefault();
      return;
    }

    // Shopify search works best by joining terms. 
    // This will search for products containing "Honda", "CBR", and the specific category.
    let searchTerms = [];
    if (brand) searchTerms.push(brand);
    if (model) searchTerms.push(model);
    if (category && category !== 'all' && category !== "") searchTerms.push(category);
    
    queryInput.value = searchTerms.join(' ');
  });
</script>

{% schema %}
{
  "name": "Moto Search Strip",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#050505"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Red)",
      "default": "#dc2626"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Elite Moto Parts"
    },
    {
      "type": "text",
      "id": "title_part1",
      "label": "Title Part 1",
      "default": "SEARCH BY"
    },
    {
      "type": "text",
      "id": "title_part2",
      "label": "Title Part 2 (Red)",
      "default": "VEHICLE"
    },
    {
      "type": "header",
      "content": "Dropdown Labels"
    },
    {
      "type": "text",
      "id": "label_brand",
      "label": "Brand Label",
      "default": "Select Brand"
    },
    {
      "type": "text",
      "id": "label_model",
      "label": "Model Label",
      "default": "Select Model"
    },
    {
      "type": "text",
      "id": "label_category",
      "label": "Category Label",
      "default": "Select Category"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "SEARCH"
    },
    {
      "type": "header",
      "content": "Options Data (Comma Separated)"
    },
    {
      "type": "textarea",
      "id": "brands",
      "label": "Brands List",
      "default": "Honda, Yamaha, Kawasaki, Suzuki, Royal Enfield, BMW, Ducati, KTM"
    },
    {
      "type": "textarea",
      "id": "models",
      "label": "Models List",
      "default": "CBR600RR, YZF-R1, Ninja 400, Classic 350, Duke 390, R1250GS, Panigale V4"
    },
    {
      "type": "textarea",
      "id": "categories",
      "label": "Categories List",
      "default": "Mirrors, Brake Pads, Exhaust Systems, Indicators / Lighting, Chain & Sprocket, Engine Oil & Filters, Tires / Wheels, Handlebars & Grips"
    }
  ],
  "presets": [
    {
      "name": "Moto Search Strip",
      "category": "Search"
    }
  ]
}
{% endschema %}