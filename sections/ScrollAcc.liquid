{%- style -%}
  .marquee-{{ section.id }} {
    --bg-color: {{ section.settings.bg_color }};
    --text-color: {{ section.settings.text_color }};
    --font-size: {{ section.settings.font_size }}px;
    --speed: {{ section.settings.speed }}s;
    --gap: {{ section.settings.gap }}px;
    background-color: var(--bg-color);
    color: var(--text-color);
    padding: {{ section.settings.padding_vertical }}px 0;
    overflow: hidden;
    white-space: nowrap;
    position: relative;
    display: flex;
    align-items: center;
    user-select: none;
    {% if section.settings.border_top %}border-top: 1px solid {{ section.settings.text_color | color_modify: 'alpha', 0.1 }};{% endif %}
    {% if section.settings.border_bottom %}border-bottom: 1px solid {{ section.settings.text_color | color_modify: 'alpha', 0.1 }};{% endif %}
  }

  .marquee-inner-{{ section.id }} {
    display: flex;
    animation: marquee-{{ section.id }} var(--speed) linear infinite;
    animation-direction: {{ section.settings.direction }};
    gap: var(--gap);
    padding-left: var(--gap);
  }

  .marquee-{{ section.id }}:hover .marquee-inner-{{ section.id }} {
    {% if section.settings.pause_on_hover %}animation-play-state: paused;{% endif %}
  }

  .marquee-item-{{ section.id }} {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    font-size: var(--font-size);
    font-weight: {{ section.settings.font_weight }};
    text-transform: {{ section.settings.text_transform }};
    text-decoration: none;
    color: inherit;
    gap: 15px;
  }

  .marquee-item-{{ section.id }} span {
     display: inline-block;
  }

  @keyframes marquee-{{ section.id }} {
    0% { transform: translateX(0); }
    100% { transform: translateX(-100%); }
  }

  /* Adjust animation for 'reverse' (right direction) */
  {% if section.settings.direction == 'reverse' %}
  @keyframes marquee-{{ section.id }} {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(0); }
  }
  {% endif %}
{%- endstyle -%}

<div class="marquee-{{ section.id }}" role="region" aria-label="Announcement Bar">
  {%- capture marquee_content -%}
    {%- for block in section.blocks -%}
      <div class="marquee-item-{{ section.id }}">
        {% if block.settings.link != blank %}<a href="{{ block.settings.link }}">{% endif %}
          {{ block.settings.text }}
        {% if block.settings.link != blank %}</a>{% endif %}
        
        {% if section.settings.show_separator and forloop.last == false or section.settings.show_separator and section.blocks.size > 1 %}
           <span class="separator">{{ section.settings.separator_text }}</span>
        {% endif %}
      </div>
    {%- endfor -%}
  {%- endcapture -%}

  <div class="marquee-inner-{{ section.id }}">
    {{ marquee_content }}
    {{ marquee_content }}
    {{ marquee_content }}
    {{ marquee_content }}
  </div>
</div>

{% schema %}
{
  "name": "Marquee Announcement",
  "settings": [
    {
      "type": "header",
      "content": "Style Settings"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 10,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Font Size",
      "default": 16
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font Weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "500"
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Text Transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "lowercase", "label": "Lowercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "uppercase"
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Vertical Padding",
      "default": 10
    },
    {
      "type": "range",
      "id": "gap",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Gap between items",
      "default": 50
    },
    {
      "type": "checkbox",
      "id": "border_top",
      "label": "Show border top",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "border_bottom",
      "label": "Show border bottom",
      "default": false
    },
    {
      "type": "header",
      "content": "Animation Settings"
    },
    {
      "type": "range",
      "id": "speed",
      "min": 5,
      "max": 100,
      "step": 5,
      "unit": "s",
      "label": "Marquee Speed (Duration)",
      "info": "Lower duration means faster speed.",
      "default": 20
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Direction",
      "options": [
        { "value": "normal", "label": "Left" },
        { "value": "reverse", "label": "Right" }
      ],
      "default": "normal"
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    },
    {
      "type": "header",
      "content": "Separator Settings"
    },
    {
      "type": "checkbox",
      "id": "show_separator",
      "label": "Show separator",
      "default": true
    },
    {
      "type": "text",
      "id": "separator_text",
      "label": "Separator Text",
      "default": "•"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free shipping on orders over $50"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee Announcement",
      "blocks": [
        { "type": "announcement" },
        { "type": "announcement" },
        { "type": "announcement" }
      ]
    }
  ]
}
{% endschema %}
