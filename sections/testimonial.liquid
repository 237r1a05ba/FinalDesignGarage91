{% style %}
  .testimonial-section-{{ section.id }} {
    padding: 80px 20px;
    background-color: {{ section.settings.bg_color }};
    text-align: center;
    overflow: hidden;
    max-width: 100vw;
  }

  .testimonial-pill-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    background-color: {{ section.settings.pill_bg_color }};
    color: {{ section.settings.pill_text_color }};
    padding: 6px 16px 6px 6px;
    border-radius: 40px;
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 24px;
    border: 1px solid {{ section.settings.pill_border_color }};
    box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.5);
  }

  .testimonial-pill-icon-{{ section.id }} {
    background-color: {{ section.settings.accent_color }};
    border-radius: 50%;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 12px;
  }

  .testimonial-heading-{{ section.id }} {
    font-size: 48px;
    font-weight: 700;
    line-height: 1.2;
    margin: 0 auto 60px;
    max-width: 800px;
    color: {{ section.settings.heading_color }};
  }

  /* Marquee Styles */
  .testimonial-marquee-{{ section.id }} {
    position: relative;
    width: 100vw;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    display: flex;
    flex-direction: column;
    gap: 24px;
    /* Fade out edges using a mask */
    mask-image: linear-gradient(to right, transparent, {{ section.settings.bg_color }} 15%, {{ section.settings.bg_color }} 85%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, {{ section.settings.bg_color }} 15%, {{ section.settings.bg_color }} 85%, transparent);
  }

  .testimonial-track-{{ section.id }} {
    display: flex;
    gap: 24px;
    width: max-content;
  }

  .testimonial-track-{{ section.id }}:hover .testimonial-group-{{ section.id }} {
    animation-play-state: paused;
  }

  .testimonial-group-{{ section.id }} {
    display: flex;
    gap: 24px;
    flex-shrink: 0;
    animation: scroll-left {{ section.settings.speed }}s linear infinite;
  }

  .testimonial-track-{{ section.id }}.reverse .testimonial-group-{{ section.id }} {
    animation: scroll-right {{ section.settings.speed }}s linear infinite;
  }

  @keyframes scroll-left {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc(-100% - 24px)); }
  }

  @keyframes scroll-right {
    0% { transform: translateX(calc(-100% - 24px)); }
    100% { transform: translateX(0); }
  }

  /* Card Styles */
  .testimonial-card-{{ section.id }} {
    width: 400px;
    background-color: {{ section.settings.card_bg_color }};
    border: 1px solid {{ section.settings.card_border_color }};
    border-radius: 16px;
    padding: 32px;
    text-align: left;
    display: flex;
    flex-direction: column;
    flex: 0 0 auto;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
  }

  .testimonial-quote-icon-{{ section.id }} {
    margin-bottom: 24px;
    fill: {{ section.settings.accent_color }};
    color: {{ section.settings.accent_color }};
  }

  .testimonial-text-{{ section.id }} {
    font-size: 16px;
    line-height: 1.6;
    color: {{ section.settings.card_text_color }};
    margin-bottom: 40px;
    flex-grow: 1;
    font-weight: 500;
  }
  
  .testimonial-text-{{ section.id }} p {
    margin: 0;
  }

  .testimonial-author-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .testimonial-author-{{ section.id }} img {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
  }

  .testimonial-avatar-placeholder-{{ section.id }} {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: {{ section.settings.bg_color }};
    border: 1px solid {{ section.settings.card_border_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ section.settings.author_title_color }};
    font-weight: 600;
    font-size: 18px;
  }

  .testimonial-author-name-{{ section.id }} {
    font-weight: 700;
    font-size: 16px;
    color: {{ section.settings.author_name_color }};
    margin-bottom: 2px;
  }

  .testimonial-author-title-{{ section.id }} {
    font-size: 14px;
    color: {{ section.settings.author_title_color }};
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .testimonial-heading-{{ section.id }} {
      font-size: 32px;
      margin-bottom: 40px;
    }
    .testimonial-card-{{ section.id }} {
      width: 300px;
      padding: 24px;
    }
    .testimonial-section-{{ section.id }} {
      padding: 60px 20px;
    }
  }
{% endstyle %}

<div class="testimonial-section-{{ section.id }}">
  {%- if section.settings.subtext != blank -%}
    <div class="testimonial-pill-{{ section.id }}">
      <div class="testimonial-pill-icon-{{ section.id }}">
        <!-- Pill icon (e.g. Star) automatically colored by accent_color -->
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="white"/>
        </svg>
      </div>
      {{ section.settings.subtext }}
    </div>
  {%- endif -%}

  {%- if section.settings.heading != blank -%}
    <h2 class="testimonial-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="testimonial-marquee-{{ section.id }}">
      
      {%- capture row1_blocks -%}
        {%- for block in section.blocks -%}
          {%- assign mod = forloop.index0 | modulo: 2 -%}
          {%- if mod == 0 -%}
            <div class="testimonial-card-{{ section.id }}" {{ block.shopify_attributes }}>
              <div class="testimonial-quote-icon-{{ section.id }}">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"></path>
                </svg>
              </div>
              <div class="testimonial-text-{{ section.id }}">{{ block.settings.quote }}</div>
              <div class="testimonial-author-{{ section.id }}">
                {% if block.settings.author_image != blank %}
                  <img src="{{ block.settings.author_image | image_url: width: 96 }}" alt="{{ block.settings.author_name }}" width="48" height="48" loading="lazy">
                {% else %}
                  <div class="testimonial-avatar-placeholder-{{ section.id }}">
                    {{ block.settings.author_name | slice: 0, 1 | upcase }}
                  </div>
                {% endif %}
                <div class="testimonial-author-info">
                  <div class="testimonial-author-name-{{ section.id }}">{{ block.settings.author_name }}</div>
                  <div class="testimonial-author-title-{{ section.id }}">{{ block.settings.author_title }}</div>
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- endcapture -%}

      {%- capture row2_blocks -%}
        {%- for block in section.blocks -%}
          {%- assign mod = forloop.index0 | modulo: 2 -%}
          {%- if mod == 1 -%}
            <div class="testimonial-card-{{ section.id }}" {{ block.shopify_attributes }}>
              <div class="testimonial-quote-icon-{{ section.id }}">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"></path>
                </svg>
              </div>
              <div class="testimonial-text-{{ section.id }}">{{ block.settings.quote }}</div>
              <div class="testimonial-author-{{ section.id }}">
                {% if block.settings.author_image != blank %}
                  <img src="{{ block.settings.author_image | image_url: width: 96 }}" alt="{{ block.settings.author_name }}" width="48" height="48" loading="lazy">
                {% else %}
                  <div class="testimonial-avatar-placeholder-{{ section.id }}">
                    {{ block.settings.author_name | slice: 0, 1 | upcase }}
                  </div>
                {% endif %}
                <div class="testimonial-author-info">
                  <div class="testimonial-author-name-{{ section.id }}">{{ block.settings.author_name }}</div>
                  <div class="testimonial-author-title-{{ section.id }}">{{ block.settings.author_title }}</div>
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- endcapture -%}

      {%- if row1_blocks != blank -%}
        <div class="testimonial-track-{{ section.id }}">
          <div class="testimonial-group-{{ section.id }}">
            {{ row1_blocks }}
          </div>
          <div class="testimonial-group-{{ section.id }}" aria-hidden="true">
            {{ row1_blocks }}
          </div>
        </div>
      {%- endif -%}

      {%- if row2_blocks != blank -%}
        <div class="testimonial-track-{{ section.id }} reverse">
          <div class="testimonial-group-{{ section.id }}">
            {{ row2_blocks }}
          </div>
          <div class="testimonial-group-{{ section.id }}" aria-hidden="true">
            {{ row2_blocks }}
          </div>
        </div>
      {%- endif -%}
      
    </div>
  {%- endif -%}
</div>

