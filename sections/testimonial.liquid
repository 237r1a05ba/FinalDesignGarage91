{% style %}
  .testimonial-section {
    padding: 80px 20px;
    background-color: #fff;
    text-align: center;
    overflow: hidden;
    max-width: 100vw;
  }

  .testimonial-pill {
    display: inline-flex;
    align-items: center;
    background-color: #111;
    color: #fff;
    padding: 6px 16px 6px 6px;
    border-radius: 40px;
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 24px;
    box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.1);
  }

  .testimonial-pill-icon {
    background-color: #2E5CFF;
    border-radius: 50%;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 12px;
  }

  .testimonial-heading {
    font-size: 48px;
    font-weight: 700;
    line-height: 1.2;
    margin: 0 auto 60px;
    max-width: 800px;
    color: #000;
  }

  /* Marquee Styles */
  .testimonial-marquee {
    position: relative;
    width: 100vw;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    display: flex;
    flex-direction: column;
    gap: 24px;
    /* Fade out edges using a mask */
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  .testimonial-track {
    display: flex;
    gap: 24px;
    width: max-content;
  }

  .testimonial-track:hover .testimonial-group {
    animation-play-state: paused;
  }

  .testimonial-group {
    display: flex;
    gap: 24px;
    flex-shrink: 0;
    animation: scroll-left {{ section.settings.speed }}s linear infinite;
  }

  .testimonial-track.reverse .testimonial-group {
    animation: scroll-right {{ section.settings.speed }}s linear infinite;
  }

  @keyframes scroll-left {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc(-100% - 24px)); }
  }

  @keyframes scroll-right {
    0% { transform: translateX(calc(-100% - 24px)); }
    100% { transform: translateX(0); }
  }

  /* Card Styles */
  .testimonial-card-{{ section.id }} {
    width: 400px;
    background-color: #F8F9FA;
    border-radius: 16px;
    padding: 32px;
    text-align: left;
    display: flex;
    flex-direction: column;
    flex: 0 0 auto;
    box-shadow: 0 4px 6px rgba(0,0,0,0.02);
  }

  .testimonial-quote-icon {
    margin-bottom: 24px;
    color: #2E5CFF;
  }

  .testimonial-text {
    font-size: 16px;
    line-height: 1.6;
    color: #111;
    margin-bottom: 40px;
    flex-grow: 1;
    font-weight: 500;
  }
  
  .testimonial-text p {
    margin: 0;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .testimonial-author img {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
  }

  .testimonial-avatar-placeholder {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: #E9ECEF;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #6C757D;
    font-weight: 600;
    font-size: 18px;
  }

  .testimonial-author-name {
    font-weight: 700;
    font-size: 16px;
    color: #000;
    margin-bottom: 2px;
  }

  .testimonial-author-title {
    font-size: 14px;
    color: #6C757D;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .testimonial-heading {
      font-size: 32px;
      margin-bottom: 40px;
    }
    .testimonial-card-{{ section.id }} {
      width: 300px;
      padding: 24px;
    }
    .testimonial-section {
      padding: 60px 20px;
    }
    .testimonial-marquee {
      mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
      -webkit-mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
    }
  }
{% endstyle %}

<div class="testimonial-section">
  {%- if section.settings.subtext != blank -%}
    <div class="testimonial-pill">
      <div class="testimonial-pill-icon">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="white"/>
        </svg>
      </div>
      {{ section.settings.subtext }}
    </div>
  {%- endif -%}

  {%- if section.settings.heading != blank -%}
    <h2 class="testimonial-heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="testimonial-marquee">
      
      {%- capture row1_blocks -%}
        {%- for block in section.blocks -%}
          {%- assign mod = forloop.index0 | modulo: 2 -%}
          {%- if mod == 0 -%}
            <div class="testimonial-card-{{ section.id }}" {{ block.shopify_attributes }}>
              <div class="testimonial-quote-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"></path>
                </svg>
              </div>
              <div class="testimonial-text">{{ block.settings.quote }}</div>
              <div class="testimonial-author">
                {% if block.settings.author_image != blank %}
                  <img src="{{ block.settings.author_image | image_url: width: 96 }}" alt="{{ block.settings.author_name }}" width="48" height="48" loading="lazy">
                {% else %}
                  <div class="testimonial-avatar-placeholder">
                    {{ block.settings.author_name | slice: 0, 1 | upcase }}
                  </div>
                {% endif %}
                <div class="testimonial-author-info">
                  <div class="testimonial-author-name">{{ block.settings.author_name }}</div>
                  <div class="testimonial-author-title">{{ block.settings.author_title }}</div>
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- endcapture -%}

      {%- capture row2_blocks -%}
        {%- for block in section.blocks -%}
          {%- assign mod = forloop.index0 | modulo: 2 -%}
          {%- if mod == 1 -%}
            <div class="testimonial-card-{{ section.id }}" {{ block.shopify_attributes }}>
              <div class="testimonial-quote-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"></path>
                </svg>
              </div>
              <div class="testimonial-text">{{ block.settings.quote }}</div>
              <div class="testimonial-author">
                {% if block.settings.author_image != blank %}
                  <img src="{{ block.settings.author_image | image_url: width: 96 }}" alt="{{ block.settings.author_name }}" width="48" height="48" loading="lazy">
                {% else %}
                  <div class="testimonial-avatar-placeholder">
                    {{ block.settings.author_name | slice: 0, 1 | upcase }}
                  </div>
                {% endif %}
                <div class="testimonial-author-info">
                  <div class="testimonial-author-name">{{ block.settings.author_name }}</div>
                  <div class="testimonial-author-title">{{ block.settings.author_title }}</div>
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- endcapture -%}

      {%- if row1_blocks != blank -%}
        <div class="testimonial-track">
          <div class="testimonial-group">
            {{ row1_blocks }}
          </div>
          <div class="testimonial-group" aria-hidden="true">
            {{ row1_blocks }}
          </div>
        </div>
      {%- endif -%}

      {%- if row2_blocks != blank -%}
        <div class="testimonial-track reverse">
          <div class="testimonial-group">
            {{ row2_blocks }}
          </div>
          <div class="testimonial-group" aria-hidden="true">
            {{ row2_blocks }}
          </div>
        </div>
      {%- endif -%}
      
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Testimonial Marquee",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Words of praise from others about our presence."
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext (Pill)",
      "default": "Rated 4/5 by over 1 Lakh users"
    },
    {
      "type": "range",
      "id": "speed",
      "min": 10,
      "max": 100,
      "step": 2,
      "unit": "s",
      "label": "Scrolling speed (seconds)",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "richtext",
          "id": "quote",
          "label": "Quote",
          "default": "<p>Their team's artistic flair and strategic approach resulted in remarkable campaigns - a reliable creative partner.</p>"
        },
        {
          "type": "image_picker",
          "id": "author_image",
          "label": "Author Image"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author Name",
          "default": "John Peter"
        },
        {
          "type": "text",
          "id": "author_title",
          "label": "Author Title/Company",
          "default": "CEO and Co-founder of ABC Company"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonial Marquee",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
