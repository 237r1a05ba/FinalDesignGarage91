{% comment %}
  Elite Moto Parts - Vehicle Search Strip + Trust Bar Redesign
  Designed for Shopify as a section.
  Redesigned Trust Bar based on image_5e153a.png
{% endcomment %}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;700;900&display=swap');

  #shopify-section-{{ section.id }} {
    --primary-red: {{ section.settings.accent_color }};
    --bg-dark: {{ section.settings.bg_color }};
    --card-bg: #0a0a0a;
    --text-white: #ffffff;
    --text-dim: rgba(255, 255, 255, 0.4);
    --border-color: rgba(255, 255, 255, 0.1);
  }

  .moto-search-wrapper {
    background-color: var(--bg-dark);
    padding: 60px 0;
    font-family: 'Inter', sans-serif;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    gap: 60px;
  }

  .moto-search-container {
    max-width: 1200px;
    width: 100%;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Header Styles */
  .moto-header {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 0 8px;
  }

  @media (min-width: 768px) {
    .moto-header {
      flex-direction: row;
      align-items: center;
      gap: 16px;
    }
  }

  .moto-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--primary-red);
  }

  .moto-badge svg {
    width: 16px;
    height: 16px;
    fill: var(--primary-red);
  }

  .moto-badge span {
    font-size: 9px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.4em;
    white-space: nowrap;
  }

  .moto-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    line-height: 1;
    color: var(--text-white);
    letter-spacing: 0.1em;
    margin: 0;
  }

  .moto-title span {
    color: var(--primary-red);
  }

  /* Search Bar Styles */
  .moto-search-bar-wrap {
    position: relative;
  }

  .moto-search-bar {
    position: relative;
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 12px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
  }

  @media (min-width: 1024px) {
    .moto-search-bar {
      flex-direction: row;
      padding: 12px;
    }
  }

  .moto-dropdown-group {
    flex: 1;
    position: relative;
  }

  .moto-select {
    width: 100%;
    height: 56px;
    background-color: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 0 16px;
    color: var(--text-white);
    font-size: 13px;
    font-weight: 500;
    appearance: none;
    cursor: pointer;
    transition: all 0.3s;
    outline: none;
  }

  .moto-select option {
    background-color: #1a1a1a;
    color: white;
  }

  .moto-chevron {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    width: 16px;
    height: 16px;
    color: #666;
    pointer-events: none;
  }

  .moto-search-btn {
    flex: 0.6;
    height: 56px;
    background-color: var(--primary-red);
    color: white;
    border: none;
    border-radius: 12px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    letter-spacing: 0.1em;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    position: relative;
    overflow: hidden;
    transition: all 0.3s;
  }

  /* ─── TRUST BAR REDESIGN (image_5e153a.png Style) ─── */
  .moto-trust-section {
    width: 100%;
    background: #000;
    border-top: 1px solid #111;
    padding: 30px 0;
    overflow: hidden;
  }

  .moto-trust-grid {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    padding: 0 40px;
  }

  @media (max-width: 991px) {
    .moto-trust-grid {
      display: none; /* Hide grid for marquee on mobile */
    }
  }

  .moto-trust-item {
    display: flex;
    align-items: center;
    gap: 15px;
    flex: 1;
  }

  .moto-trust-icon-box {
    width: 52px;
    height: 52px;
    background: #0a0a0a;
    border: 1px solid #1a1a1a;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .moto-trust-item:hover .moto-trust-icon-box {
    border-color: var(--primary-red);
    background: #110a0a;
    transform: translateY(-4px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.4);
  }

  .moto-trust-icon-box svg {
    width: 22px;
    height: 22px;
    color: #fff;
    opacity: 0.7;
  }

  .moto-trust-content {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .moto-trust-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    font-weight: 700;
    font-style: italic;
    color: #fff;
    line-height: 1;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .moto-trust-subtitle {
    font-size: 9px;
    font-weight: 600;
    color: #555;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* Mobile Marquee Logic */
  .moto-trust-marquee {
    display: none;
    width: 100%;
  }

  @media (max-width: 991px) {
    .moto-trust-marquee {
      display: block;
    }
  }

  .moto-marquee-track {
    display: flex;
    width: max-content;
    animation: motoMarquee 20s linear infinite;
  }

  @keyframes motoMarquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .moto-marquee-track .moto-trust-item {
    width: 240px;
    padding: 0 20px;
  }
</style>

<section class="moto-search-wrapper">
  <div class="moto-search-container">
    <div class="moto-header">
      <div class="moto-badge">
        <svg viewBox="0 0 24 24"><path d="M13 10V3L4 14H11V21L20 10H13Z"/></svg>
        <span>{{ section.settings.badge_text }}</span>
      </div>
      <h2 class="moto-title">
        {{ section.settings.title_part1 }} <span>{{ section.settings.title_part2 }}</span>
      </h2>
    </div>

    <div class="moto-search-bar-wrap">
      <form id="moto-search-form" action="/search" method="get" class="moto-search-bar">
        <input type="hidden" name="type" value="product">
        <input type="hidden" name="q" id="moto-final-query" value="">
        
        <div class="moto-dropdown-group">
          <select class="moto-select" id="moto-brand" required>
            <option value="" disabled selected>{{ section.settings.label_brand }}</option>
            {% assign brands = section.settings.brands_list | split: ',' %}
            {% for brand in brands %}
                <option value="{{ brand | strip | escape }}">{{ brand | strip }}</option>
            {% endfor %}
          </select>
          <svg class="moto-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </div>

        <div class="moto-dropdown-group">
          <select class="moto-select" id="moto-model" required>
            <option value="" disabled selected>{{ section.settings.label_model }}</option>
            {% assign models = section.settings.models_list | split: ',' %}
            {% for model in models %}
                <option value="{{ model | strip | escape }}">{{ model | strip }}</option>
            {% endfor %}
          </select>
          <svg class="moto-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </div>

        <div class="moto-dropdown-group">
          <select class="moto-select" id="moto-category">
            <option value="" selected>{{ section.settings.label_category }}</option>
            <option value="all">All Categories</option>
            {% assign categories = section.settings.categories_list | split: ',' %}
            {% for category in categories %}
                <option value="{{ category | strip | escape }}">{{ category | strip }}</option>
            {% endfor %}
          </select>
          <svg class="moto-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </div>

        <button type="submit" class="moto-search-btn">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
          {{ section.settings.button_text }}
        </button>
      </form>
    </div>
  </div>
</section>

<!-- REDESIGNED TRUST SECTION -->
<div class="moto-trust-section">
  <!-- Desktop Grid -->
  <div class="moto-trust-grid">
    {%- for block in section.blocks -%}
      <div class="moto-trust-item">
        <div class="moto-trust-icon-box">
          {%- case block.settings.icon -%}
            {%- when 'riders' -%}<svg viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-width="2" d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path fill="none" stroke="currentColor" stroke-width="2" d="M22 21v-2a4 4 0 0 0-3-3.87"/><path fill="none" stroke="currentColor" stroke-width="2" d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            {%- when 'secure' -%}<svg viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-width="2" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path fill="none" stroke="currentColor" stroke-width="2" d="m9 12 2 2 4-4"/></svg>
            {%- when 'premium' -%}<svg viewBox="0 0 24 24"><circle fill="none" stroke="currentColor" stroke-width="2" cx="12" cy="8" r="7"/><path fill="none" stroke="currentColor" stroke-width="2" d="M8.21 13.89 7 23l5-3 5 3-1.21-9.12"/></svg>
            {%- when 'returns' -%}<svg viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-width="2" d="M9 14 4 9l5-5"/><path fill="none" stroke="currentColor" stroke-width="2" d="M4 9h12.5A5.5 5.5 0 0 1 22 14.5v0A5.5 5.5 0 0 1 16.5 20H11"/></svg>
          {%- endcase -%}
        </div>
        <div class="moto-trust-content">
          <span class="moto-trust-title">{{ block.settings.title }}</span>
          <span class="moto-trust-subtitle">{{ block.settings.subtitle }}</span>
        </div>
      </div>
    {%- endfor -%}
  </div>

  <!-- Mobile Marquee -->
  <div class="moto-trust-marquee">
    <div class="moto-marquee-track">
      {%- capture items -%}
        {%- for block in section.blocks -%}
          <div class="moto-trust-item">
            <div class="moto-trust-icon-box">
              {%- case block.settings.icon -%}
                {%- when 'riders' -%}<svg viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-width="2" d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path fill="none" stroke="currentColor" stroke-width="2" d="M22 21v-2a4 4 0 0 0-3-3.87"/><path fill="none" stroke="currentColor" stroke-width="2" d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                {%- when 'secure' -%}<svg viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-width="2" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path fill="none" stroke="currentColor" stroke-width="2" d="m9 12 2 2 4-4"/></svg>
                {%- when 'premium' -%}<svg viewBox="0 0 24 24"><circle fill="none" stroke="currentColor" stroke-width="2" cx="12" cy="8" r="7"/><path fill="none" stroke="currentColor" stroke-width="2" d="M8.21 13.89 7 23l5-3 5 3-1.21-9.12"/></svg>
                {%- when 'returns' -%}<svg viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-width="2" d="M9 14 4 9l5-5"/><path fill="none" stroke="currentColor" stroke-width="2" d="M4 9h12.5A5.5 5.5 0 0 1 22 14.5v0A5.5 5.5 0 0 1 16.5 20H11"/></svg>
              {%- endcase -%}
            </div>
            <div class="moto-trust-content">
              <span class="moto-trust-title">{{ block.settings.title }}</span>
              <span class="moto-trust-subtitle">{{ block.settings.subtitle }}</span>
            </div>
          </div>
        {%- endfor -%}
      {%- endcapture -%}
      {{ items }}{{ items }}
    </div>
  </div>
</div>

<script>
  document.getElementById('moto-search-form').addEventListener('submit', function(e) {
    const brand = document.getElementById('moto-brand').value;
    const model = document.getElementById('moto-model').value;
    const category = document.getElementById('moto-category').value;
    const queryInput = document.getElementById('moto-final-query');
    
    if (!brand || !model) { e.preventDefault(); return; }

    let searchTerms = [];
    if (brand) searchTerms.push(brand);
    if (model) searchTerms.push(model);
    if (category && category !== 'all' && category !== "") searchTerms.push(category);
    
    queryInput.value = searchTerms.join(' ');
  });
</script>

{% schema %}
{
  "name": "Moto Search Strip",
  "max_blocks": 4,
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#050505" },
    { "type": "color", "id": "accent_color", "label": "Accent Color", "default": "#dc2626" },
    { "type": "text", "id": "badge_text", "label": "Badge Text", "default": "Elite Moto Parts" },
    { "type": "text", "id": "title_part1", "label": "Title Part 1", "default": "SEARCH BY" },
    { "type": "text", "id": "title_part2", "label": "Title Part 2", "default": "VEHICLE" },
    { "type": "header", "content": "Dropdown Labels" },
    { "type": "text", "id": "label_brand", "label": "Brand Label", "default": "Select Brand" },
    { "type": "text", "id": "label_model", "label": "Model Label", "default": "Select Model" },
    { "type": "text", "id": "label_category", "label": "Category Label", "default": "Select Category" },
    { "type": "text", "id": "button_text", "label": "Button Text", "default": "SEARCH" },
    { "type": "header", "content": "Search Data" },
    { "type": "textarea", "id": "brands_list", "label": "Brands (Comma separated)", "default": "Honda, Yamaha" },
    { "type": "textarea", "id": "models_list", "label": "Models (Comma separated)", "default": "CBR600RR, R1" },
    { "type": "textarea", "id": "categories_list", "label": "Categories (Comma separated)", "default": "Mirrors, Pads" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Trust Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "riders", "label": "Riders" },
            { "value": "secure", "label": "Secure" },
            { "value": "premium", "label": "Premium" },
            { "value": "returns", "label": "Returns" }
          ],
          "default": "riders"
        },
        { "type": "text", "id": "title", "label": "Title", "default": "2M RIDERS" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "JOURNEY WITH US" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Moto Search Strip",
      "blocks": [
        { "type": "feature", "settings": { "icon": "riders", "title": "2M RIDERS", "subtitle": "JOURNEY WITH US" } },
        { "type": "feature", "settings": { "icon": "secure", "title": "100% SECURE", "subtitle": "SECURE PAYMENT" } },
        { "type": "feature", "settings": { "icon": "premium", "title": "PREMIUM", "subtitle": "QUALITY PRODUCTS" } },
        { "type": "feature", "settings": { "icon": "returns", "title": "EASY RETURNS", "subtitle": "RETURN POLICY" } }
      ]
    }
  ]
}
{% endschema %}