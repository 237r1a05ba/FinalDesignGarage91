{%- style -%}
  :root {
    --trust-bg: {{ section.settings.bg_color | default: '#050505' }};
    --trust-accent: {{ section.settings.accent_color | default: '#3b82f6' }};
    --trust-accent-rgb: 59, 130, 246;
    --trust-text-main: #ffffff;
    --trust-text-dim: #9ca3af;
    --trust-border: rgba(255, 255, 255, 0.08);
    
    /* Dynamic Padding */
    --pt-desktop: {{ section.settings.padding_top }}px;
    --pb-desktop: {{ section.settings.padding_bottom }}px;
    --pt-mobile: {{ section.settings.padding_top_mobile }}px;
    --pb-mobile: {{ section.settings.padding_bottom_mobile }}px;

    /* Marquee Speed */
    --marquee-speed: {{ section.settings.marquee_speed }}s;
  }

  .trust-bar-v2 {
    background: var(--trust-bg);
    border-top: 1px solid var(--trust-border);
    border-bottom: 1px solid var(--trust-border);
    padding-top: var(--pt-desktop);
    padding-bottom: var(--pb-desktop);
    overflow: hidden;
    font-family: Inter, -apple-system, system-ui, sans-serif;
  }

  /* --- Desktop Grid --- */
  .trust-bar__container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
  }

  /* BUG FIX: Hide the marquee by default on Desktop */
  .trust-bar__marquee {
    display: none;
  }

  .trust-item {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 24px;
    position: relative;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    border-right: 1px solid var(--trust-border);
    cursor: default;
  }

  .trust-item:last-child { border-right: none; }

  /* Hover Effects */
  .trust-item::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(400px circle at var(--x, 50%) var(--y, 50%), rgba(255,255,255,0.04), transparent 40%);
    opacity: 0;
    transition: opacity 0.5s;
    pointer-events: none;
  }

  .trust-item:hover {
    background: rgba(255, 255, 255, 0.015);
  }

  .trust-item:hover::before {
    opacity: 1;
  }

  .trust-item__icon-box {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--trust-border);
    color: var(--trust-text-dim);
    transition: all 0.4s ease;
    flex-shrink: 0;
    z-index: 1;
  }

  .trust-item:hover .trust-item__icon-box {
    border-color: var(--trust-accent);
    color: var(--trust-accent);
    box-shadow: 0 0 15px rgba(var(--trust-accent-rgb), 0.15);
    transform: translateY(-1px);
  }

  .trust-item__icon-box svg {
    width: 16px;
    height: 16px;
    stroke-width: 1.5px;
  }

  .trust-item__text {
    display: flex;
    flex-direction: column;
    gap: 1px;
    z-index: 1;
  }

  .trust-item__title {
    color: var(--trust-text-main);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.01em;
    text-transform: uppercase;
  }

  .trust-item__subtitle {
    color: var(--trust-text-dim);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* --- Marquee Logic (Mobile/Tablet) --- */
  @media (max-width: 1024px) {
    .trust-bar-v2 {
      padding-top: var(--pt-mobile);
      padding-bottom: var(--pb-mobile);
    }

    .trust-bar__container {
      display: none;
    }

    .trust-bar__marquee {
      display: flex;
      overflow: hidden;
      user-select: none;
      padding: 4px 0;
      mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
      -webkit-mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
    }

    .trust-bar__marquee-track {
      display: flex;
      flex-shrink: 0;
      width: max-content;
      animation: scroll var(--marquee-speed) linear infinite;
    }

    @keyframes scroll {
      from { transform: translateX(0); }
      to { transform: translateX(-50%); }
    }

    .trust-item--marquee {
      flex-shrink: 0;
      width: 240px;
      border: none;
      padding: 12px 20px;
    }

    .trust-item__icon-box {
      width: 28px;
      height: 28px;
    }
    
    .trust-item__title { font-size: 12px; }
    .trust-item__subtitle { font-size: 9px; }
  }
{%- endstyle -%}

<section class="trust-bar-v2" id="TrustBar-{{ section.id }}">
  <!-- Desktop View -->
  <div class="trust-bar__container">
    {%- for block in section.blocks -%}
      <div class="trust-item" {{ block.shopify_attributes }}>
        <div class="trust-item__icon-box">
          {%- case block.settings.icon -%}
            {%- when 'riders' -%}
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" /></svg>
            {%- when 'secure' -%}
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.744c0 5.598 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.57-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" /></svg>
            {%- when 'premium' -%}
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" /></svg>
            {%- when 'returns' -%}
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3" /></svg>
            {%- when 'instagram' -%}
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3h10.5A3.75 3.75 0 0 1 21 6.75v10.5A3.75 3.75 0 0 1 17.25 21H6.75A3.75 3.75 0 0 1 3 17.25V6.75A3.75 3.75 0 0 1 6.75 3Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 15.75a3.75 3.75 0 1 0 0-7.5 3.75 3.75 0 0 0 0 7.5Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M17.625 6.375h.008v.008h-.008v-.008Z" /></svg>
          {%- endcase -%}
        </div>
        <div class="trust-item__text">
          <span class="trust-item__title">{{ block.settings.title }}</span>
          <span class="trust-item__subtitle">{{ block.settings.subtitle }}</span>
        </div>
      </div>
    {%- endfor -%}
  </div>

  <!-- Mobile Marquee -->
  <div class="trust-bar__marquee">
    <div class="trust-bar__marquee-track">
      {%- comment -%} Double loop for seamless infinite scrolling {%- endcomment -%}
      {%- for i in (1..2) -%}
        {%- for block in section.blocks -%}
          <div class="trust-item trust-item--marquee">
            <div class="trust-item__icon-box">
              {%- case block.settings.icon -%}
                {%- when 'riders' -%}<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" /></svg>
                {%- when 'secure' -%}<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.744c0 5.598 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.57-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" /></svg>
                {%- when 'premium' -%}<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" /></svg>
                {%- when 'returns' -%}<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3" /></svg>
                {%- when 'instagram' -%}<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3h10.5A3.75 3.75 0 0 1 21 6.75v10.5A3.75 3.75 0 0 1 17.25 21H6.75A3.75 3.75 0 0 1 3 17.25V6.75A3.75 3.75 0 0 1 6.75 3Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 15.75a3.75 3.75 0 1 0 0-7.5 3.75 3.75 0 0 0 0 7.5Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M17.625 6.375h.008v.008h-.008v-.008Z" /></svg>
              {%- endcase -%}
            </div>
            <div class="trust-item__text">
              <span class="trust-item__title">{{ block.settings.title }}</span>
              <span class="trust-item__subtitle">{{ block.settings.subtitle }}</span>
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
  (function() {
    // Only run on non-touch devices for better performance
    const items = document.querySelectorAll('.trust-item');
    if (items.length > 0) {
      items.forEach(item => {
        item.addEventListener('mousemove', e => {
          const rect = item.getBoundingClientRect();
          item.style.setProperty('--x', (e.clientX - rect.left) + 'px');
          item.style.setProperty('--y', (e.clientY - rect.top) + 'px');
        });
      });
    }
  })();
</script>

