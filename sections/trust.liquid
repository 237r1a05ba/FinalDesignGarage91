{%- style -%}
  /* ─── Wrapper ─────────────────────────────────────────── */
  .feature-bar-section {
    background: #0a0a0a;
    border-top: 1px solid #1e1e1e;
    border-bottom: 1px solid #1e1e1e;
    overflow: hidden;
    color: #ffffff;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    position: relative;
  }

  /* Subtle top gradient accent line */
  .feature-bar-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, #3b82f6 30%, #a855f7 70%, transparent 100%);
    opacity: 0.6;
  }

  /* ─── Desktop Layout ───────────────────────────────────── */
  .feature-bar__desktop {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    align-items: stretch;
  }

  .feature-bar__item {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 20px 28px;
    position: relative;
    transition: background 0.4s ease;
    cursor: default;
    border-right: 1px solid #1e1e1e;
    overflow: hidden;
  }

  .feature-bar__item:last-child {
    border-right: none;
  }

  /* Shimmer sweep on hover */
  .feature-bar__item::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.04) 50%, transparent 60%);
    transform: translateX(-100%);
    transition: none;
  }

  .feature-bar__item:hover::before {
    animation: trustShimmer 0.8s ease forwards;
  }

  @keyframes trustShimmer {
    to { transform: translateX(250%); }
  }

  .feature-bar__item:hover {
    background: rgba(255, 255, 255, 0.025);
  }

  /* Bottom gradient accent */
  .feature-bar__item::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, #3b82f6, #a855f7);
    transition: width 0.45s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .feature-bar__item:hover::after {
    width: 100%;
  }

  /* ─── Icon ─────────────────────────────────────────────── */
  .feature-bar__icon-wrap {
    flex-shrink: 0;
    width: 46px;
    height: 46px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.4s ease;
  }

  .feature-bar__item:hover .feature-bar__icon-wrap {
    background: rgba(59, 130, 246, 0.12);
    border-color: rgba(59, 130, 246, 0.3);
    box-shadow: 0 0 18px rgba(59, 130, 246, 0.2);
    transform: scale(1.06);
  }

  .feature-bar__icon {
    width: 22px;
    height: 22px;
    color: #a0aec0;
    transition: color 0.4s ease, transform 0.4s ease;
  }

  .feature-bar__item:hover .feature-bar__icon {
    color: #60a5fa;
    transform: scale(1.1);
  }

  .feature-bar__icon svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* ─── Text ─────────────────────────────────────────────── */
  .feature-bar__content {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .feature-bar__title {
    font-size: 0.95rem;
    font-weight: 900;
    text-transform: uppercase;
    font-style: italic;
    letter-spacing: -0.01em;
    line-height: 1.15;
    white-space: nowrap;
    color: #f5f5f5;
    transition: color 0.3s ease;
  }

  .feature-bar__item:hover .feature-bar__title {
    color: #ffffff;
  }

  .feature-bar__subtitle {
    font-size: 8.5px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #525252;
    white-space: nowrap;
    transition: color 0.3s ease;
  }

  .feature-bar__item:hover .feature-bar__subtitle {
    color: #737373;
  }

  /* ─── Mobile slide-in ─────────────────────────────────── */
  .feature-bar__mobile {
    display: none;
  }

  @media (max-width: 768px) {
    .feature-bar__desktop {
      display: none;
    }

    .feature-bar__mobile {
      display: block;
      position: relative;
      height: 72px;
      overflow: hidden;
    }

    /* Each mobile item is absolutely stacked */
    .feature-bar__mobile .feature-bar__item {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 14px;
      padding: 0 24px;
      border-right: none;
      /* initial off-screen state set by JS */
      transform: translateX(100%);
      opacity: 0;
      will-change: transform, opacity;
    }

    /* No underline sweep on mobile */
    .feature-bar__mobile .feature-bar__item::after {
      display: none;
    }

    .feature-bar__mobile .feature-bar__icon-wrap {
      width: 40px;
      height: 40px;
      border-radius: 10px;
    }

    .feature-bar__mobile .feature-bar__icon {
      width: 19px;
      height: 19px;
    }

    .feature-bar__mobile .feature-bar__title {
      font-size: 0.88rem;
    }

    .feature-bar__mobile .feature-bar__subtitle {
      font-size: 7.5px;
    }
  }
{%- endstyle -%}

{%- capture feature_items_html -%}
  {%- for block in section.blocks -%}
    <div class="feature-bar__item" {{ block.shopify_attributes }}>
      <div class="feature-bar__icon-wrap">
        <div class="feature-bar__icon">
          {%- case block.settings.icon -%}
            {%- when 'riders' -%}
              <svg viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            {%- when 'secure' -%}
              <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
            {%- when 'premium' -%}
              <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
            {%- when 'returns' -%}
              <svg viewBox="0 0 24 24"><path d="M9 14 4 9l5-5"/><path d="M4 9h12.5A5.5 5.5 0 0 1 22 14.5v0A5.5 5.5 0 0 1 16.5 20H11"/></svg>
          {%- endcase -%}
        </div>
      </div>
      <div class="feature-bar__content">
        <span class="feature-bar__title">{{ block.settings.title }}</span>
        <span class="feature-bar__subtitle">{{ block.settings.subtitle }}</span>
      </div>
    </div>
  {%- endfor -%}
{%- endcapture -%}

<section class="feature-bar-section">

  {{- '<!-- Desktop -->' -}}
  <div class="feature-bar__desktop">
    {{ feature_items_html }}
  </div>

  {{- '<!-- Mobile slide-in (one item at a time) -->' -}}
  <div class="feature-bar__mobile">
    {%- for block in section.blocks -%}
      <div class="feature-bar__item" {{ block.shopify_attributes }}>
        <div class="feature-bar__icon-wrap">
          <div class="feature-bar__icon">
            {%- case block.settings.icon -%}
              {%- when 'riders' -%}
                <svg viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              {%- when 'secure' -%}
                <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
              {%- when 'premium' -%}
                <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
              {%- when 'returns' -%}
                <svg viewBox="0 0 24 24"><path d="M9 14 4 9l5-5"/><path d="M4 9h12.5A5.5 5.5 0 0 1 22 14.5v0A5.5 5.5 0 0 1 16.5 20H11"/></svg>
            {%- endcase -%}
          </div>
        </div>
        <div class="feature-bar__content">
          <span class="feature-bar__title">{{ block.settings.title }}</span>
          <span class="feature-bar__subtitle">{{ block.settings.subtitle }}</span>
        </div>
      </div>
    {%- endfor -%}
  </div>

</section>

<script>
(function () {
  var mobile = document.querySelector('.feature-bar__mobile');
  if (!mobile) return;

  // Only activate on mobile widths
  function init() {
    var items = Array.from(mobile.querySelectorAll('.feature-bar__item'));
    if (items.length < 2) {
      // Show single item statically
      if (items[0]) { items[0].style.transform = 'translateX(0)'; items[0].style.opacity = '1'; }
      return;
    }

    var current = 0;
    var HOLD     = 2400;  // ms each item is visible
    var DURATION = 450;   // ms slide transition

    function place(item, x, opacity, animated) {
      item.style.transition = animated
        ? 'transform ' + DURATION + 'ms cubic-bezier(0.4,0,0.2,1), opacity ' + DURATION + 'ms ease'
        : 'none';
      item.style.transform  = 'translateX(' + x + '%)';
      item.style.opacity    = opacity;
    }

    // Show first item immediately, rest off-screen to the right
    items.forEach(function (item, i) { place(item, i === 0 ? 0 : 100, i === 0 ? '1' : '0', false); });

    function advance() {
      var outgoing = items[current];
      var next     = (current + 1) % items.length;
      var incoming = items[next];

      // Reset incoming to right without animation, then slide in
      place(incoming, 100, '0', false);
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          place(outgoing, -100, '0', true);   // slide current out left
          place(incoming,    0, '1', true);   // slide next in from right
        });
      });

      current = next;
    }

    setInterval(advance, HOLD);
  }

  // Run only on mobile breakpoint
  if (window.matchMedia('(max-width: 768px)').matches) { init(); }
  window.matchMedia('(max-width: 768px)').addEventListener('change', function (e) {
    if (e.matches) { init(); }
  });
})();
</script>

{% schema %}
{
  "name": "Feature Trust Bar",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "riders", "label": "Users/Riders" },
            { "value": "secure", "label": "Shield/Secure" },
            { "value": "premium", "label": "Award/Premium" },
            { "value": "returns", "label": "Return Arrow" }
          ],
          "default": "riders"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Supporting text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Feature Trust Bar",
      "blocks": [
        { "type": "feature", "settings": { "icon": "riders", "title": "2M Riders", "subtitle": "Journey With Us" } },
        { "type": "feature", "settings": { "icon": "secure", "title": "100% Secure", "subtitle": "Secure Payment" } },
        { "type": "feature", "settings": { "icon": "premium", "title": "Premium", "subtitle": "Quality Products" } },
        { "type": "feature", "settings": { "icon": "returns", "title": "Easy Returns", "subtitle": "Return Policy" } }
      ]
    }
  ]
}
{% endschema %}