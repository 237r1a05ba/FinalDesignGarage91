{% doc %}
  @prompt
    add the New Tag on the product when beside the sale tag and this has to be done only when i add the New tag in the product tags 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-badges-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.badge_spacing }}px;
    align-items: center;
    width: {{ block.settings.desktop_width_percent }}%;
  }

  .ai-product-badge-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.badge_padding_vertical }}px {{ block.settings.badge_padding_horizontal }}px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: {{ block.settings.badge_font_weight }};
    text-transform: {{ block.settings.badge_text_transform }};
    line-height: 1.2;
  }

  .ai-product-badge-sale-{{ ai_gen_id }} {
    background-color: {{ block.settings.sale_background_color }};
    color: {{ block.settings.sale_text_color }};
  }

  .ai-product-badge-new-{{ ai_gen_id }} {
    background-color: {{ block.settings.new_background_color }};
    color: {{ block.settings.new_text_color }};
  }
{% endstyle %}

<div class="ai-product-badges-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if product.compare_at_price > product.price %}
    <span class="ai-product-badge-{{ ai_gen_id }} ai-product-badge-sale-{{ ai_gen_id }}">
      {{ block.settings.sale_text }}
    </span>
  {% endif %}

  {% if product.tags contains 'New' or product.tags contains 'new' %}
    <span class="ai-product-badge-{{ ai_gen_id }} ai-product-badge-new-{{ ai_gen_id }}">
      {{ block.settings.new_text }}
    </span>
  {% endif %}
</div>

{% schema %}
{
  "name": "Product badges",
  "settings": [
    {
      "type": "header",
      "content": "Sale badge"
    },
    {
      "type": "text",
      "id": "sale_text",
      "label": "Sale text",
      "default": "Sale"
    },
    {
      "type": "color",
      "id": "sale_background_color",
      "label": "Background color",
      "default": "#e30000"
    },
    {
      "type": "color",
      "id": "sale_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "New badge"
    },
    {
      "type": "text",
      "id": "new_text",
      "label": "New text",
      "default": "New"
    },
    {
      "type": "color",
      "id": "new_background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "new_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Badge style"
    },
    {
      "type": "range",
      "id": "badge_font_size",
      "label": "Font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "select",
      "id": "badge_font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Regular"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semibold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "600"
    },
    {
      "type": "select",
      "id": "badge_text_transform",
      "label": "Text case",
      "options": [
        {
          "value": "none",
          "label": "Default"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        }
      ],
      "default": "uppercase"
    },
    {
      "type": "range",
      "id": "badge_padding_vertical",
      "label": "Vertical padding",
      "min": 2,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 6
    },
    {
      "type": "range",
      "id": "badge_padding_horizontal",
      "label": "Horizontal padding",
      "min": 4,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "badge_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "badge_spacing",
      "label": "Space between badges",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Product badges"
    }
  ]
}
{% endschema %}
